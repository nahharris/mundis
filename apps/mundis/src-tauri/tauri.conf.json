{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mundis",
  "version": "0.1.0",
  "identifier": "dev.harrisonn.mundis",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mundis",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
